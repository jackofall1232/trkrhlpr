<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="lastwagon.db-shm" />
        <exclude domain="database" path="lastwagon.db-wal" />
        <!-- Driver-supplied API credentials never leave the device. -->
        <exclude domain="file" path="datastore/local_secrets.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/local_secrets.preferences_pb" />
    </device-transfer>
</data-extraction-rules>

